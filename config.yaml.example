# Pi Audio Client Configuration

server:
  url: "http://localhost:8099"  # Hermes gateway URL (or set PI_SERVER_URL env var)
  api_key: ""  # Optional API key (or set PI_API_KEY env var)
  device_id: "pi-audio-1"  # Device ID for session tracking

audio:
  input_device: null  # USB mic (null = default)
  output_device: null  # Speaker/headphones (null = default)
  sample_rate: 16000  # Start here unless your device requires a different rate
  chunk_size: 1024

gpio:
  led_idle: 6       # Green LED (physical pin 31)
  led_listening: 13  # Red LED (physical pin 33)
  button_ptt: 19     # Push-to-talk button (physical pin 35)
  button_cancel: 5   # Cancel button (physical pin 29)

state:
  hold_threshold: 0.5  # Seconds to hold PTT before recording
  max_recording_secs: 30  # Maximum recording duration
  timeout_idle: 30  # Reserved for future idle timeout handling
  timeout_speaking: 60  # Reserved for future speaking timeout handling

debug_log_transcripts: false  # Set true only when debugging conversational content
